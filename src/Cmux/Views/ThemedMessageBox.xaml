<Window x:Class="Cmux.Views.ThemedMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" Height="Auto" Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        MaxHeight="500">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" CornerRadius="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.4" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}"
                    CornerRadius="10,10,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock x:Name="TitleText" Foreground="{DynamicResource ForegroundDimBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0" />
                    <Button Style="{StaticResource WindowCloseButton}" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_Click" Width="38" Height="32">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <TextBlock x:Name="IconText" Grid.Column="0"
                               FontFamily="Segoe MDL2 Assets" FontSize="28"
                               VerticalAlignment="Top" Margin="0,2,14,0" />

                    <!-- Message -->
                    <TextBlock x:Name="MessageText" Grid.Column="1"
                               Foreground="{DynamicResource ForegroundBrush}"
                               TextWrapping="Wrap"
                               FontSize="13"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button x:Name="BtnCancel" Content="{DynamicResource Prompt_Cancel}"
                            Style="{StaticResource CmuxButton}" Padding="14,7" Margin="0,0,8,0"
                            Click="Cancel_Click" Visibility="Collapsed"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="BtnNo" Content="{DynamicResource MsgBox_No}"
                            Style="{StaticResource CmuxButton}" Padding="14,7" Margin="0,0,8,0"
                            Click="No_Click" Visibility="Collapsed"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="BtnYes" Content="{DynamicResource MsgBox_Yes}"
                            Style="{StaticResource AccentButton}" Padding="14,7" Margin="0,0,8,0"
                            Click="Yes_Click" Visibility="Collapsed"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="BtnOk" Content="{DynamicResource MsgBox_OK}"
                            Style="{StaticResource AccentButton}" Padding="14,7"
                            Click="Ok_Click" IsDefault="True"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
