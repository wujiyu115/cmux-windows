<Window x:Class="Cmux.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Cmux.ViewModels"
        xmlns:views="clr-namespace:Cmux.Views"
        xmlns:controls="clr-namespace:Cmux.Controls"
        Title="{DynamicResource App_Title}" Height="800" Width="1200"
        MinHeight="400" MinWidth="600"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Loaded="OnLoaded" Closing="OnClosing"
        KeyDown="OnKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                      ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF141420" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFE2E2E9" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF252547" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFE2E2E9" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF141420" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF141420" />

        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF141420" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#FF252547" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF2A2A3C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FF2A2A3C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FF2A2A3C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FF2A2A3C" />

        <Style x:Key="AppMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource SidebarBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <Style x:Key="AppMenuTopItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="TopItemBg" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}">
                                <Border Background="#FF141420" BorderBrush="#FF2A2A3C" BorderThickness="1" Padding="4" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopItemBg" Property="Background" Value="#FF1A1A2E" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopItemBg" Property="Background" Value="#FF1A1A2E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppMenuSubItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="SubItemBg" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Header" RecognizesAccessKey="True" />
                                <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}" Margin="14,0,0,0"
                                           Foreground="{StaticResource ForegroundDimBrush}" FontSize="11" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="SubItemBg" Property="Background" Value="#FF252547" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource ForegroundDimBrush}" />
                                <Setter TargetName="SubItemBg" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Margin="6,4" Background="#FF2A2A3C" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border x:Name="WindowBorder" Background="{StaticResource BackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Clip>
            <RectangleGeometry x:Name="WindowClipGeometry" RadiusX="10" RadiusY="10" />
        </Border.Clip>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Height="38">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Menu items -->
                        <ColumnDefinition Width="*" />    <!-- Drag area -->
                        <ColumnDefinition Width="Auto" /> <!-- Window buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- Menu items (left side) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="{DynamicResource App_Brand}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="14,0,12,0" />
                        <Menu Style="{StaticResource AppMenuStyle}" VerticalAlignment="Center">
                            <Menu.Resources>
                                <Style TargetType="Separator" BasedOn="{StaticResource AppMenuSeparatorStyle}" />
                            </Menu.Resources>
                            <MenuItem Header="{DynamicResource Menu_File}" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="{DynamicResource Menu_NewWorkspace}" Command="{Binding CreateNewWorkspaceCommand}" InputGestureText="Ctrl+N" />
                                <MenuItem Header="{DynamicResource Menu_NewSurface}" Command="{Binding SelectedWorkspace.CreateNewSurfaceCommand}" InputGestureText="Ctrl+T" />
                                <Separator />
                                <MenuItem Header="{DynamicResource Menu_OpenCommandLogs}" Click="MenuOpenLogs_Click" InputGestureText="Ctrl+Shift+L" />
                                <MenuItem Header="{DynamicResource Menu_OpenSessionVault}" Click="MenuOpenSessionVault_Click" InputGestureText="Ctrl+Shift+V" />
                                <Separator />
                                <MenuItem Header="{DynamicResource Menu_Settings}" Click="MenuOpenSettings_Click" InputGestureText="Ctrl+," />
                                <Separator />
                                <MenuItem Header="{DynamicResource Menu_Exit}" Click="CloseButton_Click" />
                            </MenuItem>
                            <MenuItem Header="{DynamicResource Menu_Window}" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="{DynamicResource Menu_SplitRight}" Click="ToolbarSplitRight_Click" InputGestureText="Ctrl+D" />
                                <MenuItem Header="{DynamicResource Menu_SplitDown}" Click="ToolbarSplitDown_Click" InputGestureText="Ctrl+Shift+D" />
                                <MenuItem Header="{DynamicResource Menu_ZoomPane}" Click="ToolbarZoom_Click" InputGestureText="Ctrl+Shift+Z" />
                                <MenuItem Header="{DynamicResource Menu_EqualizePanes}" Click="ToolbarEqualize_Click" />
                                <Separator />
                                <MenuItem Header="{DynamicResource Menu_Search}" Click="Search_Click" InputGestureText="Ctrl+Shift+F" />
                                <MenuItem Header="{DynamicResource Menu_CommandPalette}" Click="CommandPalette_Click" InputGestureText="Ctrl+Shift+P" />
                                <MenuItem Header="{DynamicResource Menu_Snippets}" Click="Snippets_Click" />
                                <Separator />
                                <MenuItem Header="{DynamicResource Menu_ToggleAgentChat}" Click="MenuToggleAgentChat_Click" InputGestureText="Ctrl+Shift+A" />
                                <MenuItem Header="{DynamicResource Menu_ToggleSidebar}" Command="{Binding ToggleSidebarCommand}" InputGestureText="Ctrl+B" />
                            </MenuItem>
                            <MenuItem Header="{DynamicResource Menu_Help}" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="{DynamicResource Menu_KeyboardShortcuts}" Click="MenuOpenKeyboardShortcuts_Click" />
                                <MenuItem Header="{DynamicResource Menu_About}" Click="MenuAbout_Click" />
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <!-- Drag area (center) -->
                    <Border Grid.Column="1" Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

                    <!-- Window control buttons (right side) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowChromeButton}" Click="MinimizeButton_Click"
                                ToolTip="{DynamicResource Window_Minimize}">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button x:Name="MaxRestoreButton" Style="{StaticResource WindowChromeButton}"
                                Click="MaximizeButton_Click" ToolTip="{DynamicResource Window_Maximize}">
                            <TextBlock x:Name="MaxRestoreIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click"
                                ToolTip="{DynamicResource Window_Close}">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="280" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Sidebar top actions -->
                        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="8,8,8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                                    <TextBlock Text="{DynamicResource Sidebar_Workspaces}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="{DynamicResource Sidebar_ManageSessions}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Sidebar_NewWorkspaceTooltip}"
                                            Width="24" Height="24" Command="{Binding CreateNewWorkspaceCommand}">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Sidebar_SessionVaultTooltip}"
                                            Width="24" Height="24" Click="MenuOpenSessionVault_Click">
                                        <TextBlock Text="&#xE8D1;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Sidebar_CommandLogsTooltip}"
                                            Width="24" Height="24" Click="MenuOpenLogs_Click">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                </StackPanel>

                                <TextBox x:Name="WorkspaceFilterBox"
                                         Grid.Row="1" Grid.ColumnSpan="2"
                                         Margin="0,8,0,0" Padding="8,5"
                                         Background="#FF141420" Foreground="{StaticResource ForegroundBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         CaretBrush="{StaticResource ForegroundBrush}" SelectionBrush="{StaticResource AccentBrush}"
                                         ToolTip="{DynamicResource Sidebar_FilterTooltip}"
                                         TextChanged="WorkspaceFilterBox_TextChanged" />
                            </Grid>
                        </Border>

                        <!-- Workspace list -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding Workspaces}"
                                 SelectedItem="{Binding SelectedWorkspace}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 AllowDrop="True" Padding="4,4,4,0"
                                 x:Name="WorkspaceList">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
                                    <controls:WorkspaceSidebarItem />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,1" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <!-- Active indicator bar (left edge) -->
                                                    <Rectangle x:Name="activeBar" Width="3" HorizontalAlignment="Left"
                                                               RadiusX="1.5" RadiusY="1.5" Opacity="0"
                                                               Margin="0,4">
                                                        <Rectangle.Fill>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                <GradientStop Color="#FF6366F1" Offset="0" />
                                                                <GradientStop Color="#FFA78BFA" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Rectangle.Fill>
                                                    </Rectangle>
                                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                                            CornerRadius="8" Padding="10,8" Margin="6,0,2,0">
                                                        <ContentPresenter />
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{StaticResource SidebarItemHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{StaticResource SidebarItemSelectedBrush}" />
                                                        <Setter TargetName="activeBar" Property="Opacity" Value="1" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="WorkspaceItem_PreviewMouseDown" />
                                    <EventSetter Event="PreviewMouseMove" Handler="WorkspaceItem_PreviewMouseMove" />
                                    <EventSetter Event="Drop" Handler="WorkspaceItem_Drop" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Sidebar footer -->
                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0" Padding="6,6">
                            <StackPanel>
                                <Button Command="{Binding CreateNewWorkspaceCommand}"
                                        Style="{StaticResource CmuxButton}"
                                        HorizontalAlignment="Stretch" Margin="0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Margin="0,0,8,0" Opacity="0.6" />
                                        <TextBlock Text="{DynamicResource Sidebar_NewWorkspace}" FontSize="12" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding ToggleNotificationPanelCommand}"
                                        Style="{StaticResource CmuxButton}"
                                        HorizontalAlignment="Stretch" Margin="0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Margin="0,0,8,0" Opacity="0.6" />
                                            <TextBlock Text="{DynamicResource Sidebar_Notifications}" FontSize="12" />
                                        </StackPanel>
                                        <Border CornerRadius="10"
                                                Padding="6,2" HorizontalAlignment="Right"
                                                Visibility="{Binding TotalUnreadCount, Converter={StaticResource IntToVisibility}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF6366F1" Offset="0" />
                                                    <GradientStop Color="#FFA78BFA" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding TotalUnreadCount}" FontSize="10"
                                                       Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Vertical divider -->
                <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                              HorizontalAlignment="Stretch" />

                <!-- Content area -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Surface tabs -->
                        <RowDefinition Height="Auto" /> <!-- Toolbar -->
                        <RowDefinition Height="*" />    <!-- Terminal content -->
                        <RowDefinition Height="Auto" /> <!-- Status bar -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="AgentChatColumn" Width="0" />
                    </Grid.ColumnDefinitions>

                    <!-- Surface tabs -->
                    <controls:SurfaceTabBar x:Name="SurfaceTabBarControl" Grid.Row="0" Grid.Column="0"
                        DataContext="{Binding SelectedWorkspace}" />

                    <!-- Toolbar -->
                    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="6,2">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_SplitRight}"
                                    Click="ToolbarSplitRight_Click">
                                <TextBlock Text="&#xE26B;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_SplitDown}"
                                    Click="ToolbarSplitDown_Click">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Button x:Name="ShellSelectorButton" Style="{StaticResource IconButton}"
                                    ToolTip="{DynamicResource Toolbar_OpenShell}"
                                    Click="ShellSelector_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="7" Margin="2,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_Layout2Col}"
                                    Click="ToolbarLayout2Col_Click">
                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_LayoutGrid}"
                                    Click="ToolbarLayoutGrid_Click">
                                <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_LayoutMainStack}"
                                    Click="ToolbarLayoutMainStack_Click">
                                <TextBlock Text="&#xE89F;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_Equalize}"
                                    Click="ToolbarEqualize_Click">
                                <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button x:Name="ToolbarZoomButton" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_ZoomPane}"
                                    Click="ToolbarZoom_Click">
                                <TextBlock x:Name="ToolbarZoomIcon" Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button x:Name="ToolbarAgentChatButton" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Toolbar_AgentChat}"
                                    Click="ToggleAgentChat_Click">
                                <TextBlock Text="&#xE11B;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Terminal content -->
                    <ContentControl Grid.Row="2" Grid.Column="0" x:Name="ContentArea">
                        <controls:SplitPaneContainer x:Name="SplitPaneContainerControl"
                            DataContext="{Binding SelectedWorkspace.SelectedSurface}" />
                    </ContentControl>

                    <!-- Notification panel overlay -->
                    <controls:NotificationPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        HorizontalAlignment="Right"
                        Visibility="{Binding NotificationPanelVisible, Converter={StaticResource BoolToVisibility}}"
                        DataContext="{Binding}" />

                    <!-- Command palette overlay -->
                    <controls:CommandPalette Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        x:Name="CommandPaletteControl"
                        Visibility="Collapsed" />

                    <!-- Snippet picker overlay -->
                    <controls:SnippetPicker Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        x:Name="SnippetPickerControl"
                        Visibility="Collapsed" />

                    <!-- Status bar -->
                    <Border Grid.Row="3" Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="10,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <!-- Git branch -->
                                <TextBlock Text="&#xE8AD;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock Text="{Binding SelectedWorkspace.GitBranch, FallbackValue=''}" FontSize="11"
                                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <!-- Working directory -->
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock Text="{Binding SelectedWorkspace.WorkingDirectory, FallbackValue=''}" FontSize="11"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="300" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <!-- Pane count -->
                                <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock x:Name="PaneCountText" Text="{DynamicResource Status_PanesSingular}" FontSize="11"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <!-- Daemon status -->
                                <Border x:Name="DaemonStatusBorder" CornerRadius="3" Padding="5,1" Margin="0,0,12,0"
                                        VerticalAlignment="Center" Background="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="DaemonStatusDot" Width="6" Height="6"
                                                 Fill="#FF6B7280" Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock x:Name="DaemonStatusText" Text="{DynamicResource Status_Daemon}" FontSize="10"
                                                   Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <!-- Shortcuts hint -->
                                <TextBlock Text="{DynamicResource Status_CommandsHint}" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Agent chat panel -->
                    <Border x:Name="AgentChatPanel"
                            Grid.Row="0" Grid.RowSpan="4" Grid.Column="1"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                            Background="{StaticResource SidebarBackgroundBrush}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{DynamicResource Agent_Title}" Foreground="{StaticResource ForegroundBrush}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{DynamicResource Agent_Subtitle}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Agent_HideChat}"
                                            Click="ToggleAgentChat_Click">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="10,8,10,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox x:Name="AgentThreadSearchBox" Grid.Column="1" Style="{StaticResource CmuxTextBox}"
                                         Height="28" VerticalContentAlignment="Center"
                                         TextChanged="AgentThreadSearchBox_TextChanged"
                                         ToolTip="{DynamicResource Agent_SearchThreads}" />
                                <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="6,0,0,0"
                                        ToolTip="{DynamicResource Agent_NewThread}" Click="AgentNewThread_Click">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                </Button>
                                <Button Grid.Column="3" Style="{StaticResource IconButton}" Margin="4,0,0,0"
                                        ToolTip="{DynamicResource Agent_RefreshThreads}" Click="AgentRefreshThreads_Click">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                </Button>
                            </Grid>

                            <ListBox x:Name="AgentThreadsList"
                                     Grid.Row="2" Height="120" Margin="10,0,10,6"
                                     SelectionChanged="AgentThreadsList_SelectionChanged"
                                     Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,3">
                                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource ForegroundBrush}" FontSize="11" />
                                            <TextBlock Text="{Binding Meta}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="3" Margin="10,0,10,6">
                                <TextBlock x:Name="AgentStatusText" Text="{DynamicResource Agent_Idle}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                <TextBlock x:Name="AgentUsageText" Text="{DynamicResource Agent_UsageDefault}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                <TextBlock x:Name="AgentContextText" Text="{DynamicResource Agent_ContextDefault}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBox x:Name="AgentMessageSearchBox" Grid.Column="1" Style="{StaticResource CmuxTextBox}" Height="28"
                                             VerticalContentAlignment="Center"
                                             ToolTip="{DynamicResource Agent_SearchMessages}"
                                             TextChanged="AgentMessageSearchBox_TextChanged" />
                                </Grid>
                            </StackPanel>

                            <ListBox x:Name="AgentMessagesList" Grid.Row="4" Margin="10,0,10,8"
                                     Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Margin="4,3" CornerRadius="6" Background="#221A1A2E"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Header}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                                <TextBlock Text="{Binding Content}" Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Meta}" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid Grid.Row="5" Margin="10,0,10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AgentPromptBox" Grid.Column="0" Style="{StaticResource CmuxTextBox}"
                                         MinHeight="56" MaxHeight="160" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         PreviewKeyDown="AgentPromptBox_PreviewKeyDown" />
                                <Button Grid.Column="1" Margin="8,0,0,0" Padding="10,6"
                                        Style="{StaticResource AccentButton}"
                                        Content="{DynamicResource Agent_Send}"
                                        Click="AgentSend_Click" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
