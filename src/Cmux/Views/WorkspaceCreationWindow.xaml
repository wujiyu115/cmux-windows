<Window x:Class="Cmux.Views.WorkspaceCreationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WorkspaceCreate_Title}" Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" CornerRadius="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.4" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}"
                    CornerRadius="10,10,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="{DynamicResource WorkspaceCreate_Title}" Foreground="{DynamicResource ForegroundDimBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0" />
                    <Button Style="{StaticResource WindowCloseButton}" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Cancel_Click" Width="38" Height="32">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" Text="{DynamicResource WorkspaceCreate_Name}"
                           Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,4" />
                <TextBox x:Name="NameBox" Grid.Row="1" Style="{StaticResource CmuxTextBox}"
                         KeyDown="NameBox_KeyDown" />

                <!-- Default Terminal -->
                <TextBlock Grid.Row="2" Text="{DynamicResource WorkspaceCreate_Shell}"
                           Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,10,0,4" />
                <ComboBox x:Name="ShellCombo" Grid.Row="3" />

                <!-- Group -->
                <TextBlock Grid.Row="4" Text="{DynamicResource WorkspaceCreate_Group}"
                           Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,10,0,4" />
                <ComboBox x:Name="GroupCombo" Grid.Row="5" />

                <!-- Accent Color -->
                <TextBlock Grid.Row="6" Text="{DynamicResource WorkspaceCreate_Color}"
                           Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,10,0,4" />
                <StackPanel Grid.Row="7" Orientation="Horizontal" x:Name="ColorPanel">
                    <Button Tag="#FF818CF8" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FF818CF8" />
                    </Button>
                    <Button Tag="#FF10B981" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FF10B981" />
                    </Button>
                    <Button Tag="#FFF59E0B" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FFF59E0B" />
                    </Button>
                    <Button Tag="#FFEF4444" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FFEF4444" />
                    </Button>
                    <Button Tag="#FF06B6D4" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FF06B6D4" />
                    </Button>
                    <Button Tag="#FFA855F7" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FFA855F7" />
                    </Button>
                    <Button Tag="#FF64748B" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FF64748B" />
                    </Button>
                    <Button Tag="#FFEC4899" Click="ColorPreset_Click" Style="{StaticResource IconButton}" Width="28" Height="28" Margin="0,0,4,0">
                        <Ellipse Width="18" Height="18" Fill="#FFEC4899" />
                    </Button>
                    <Button Click="ColorCustom_Click" Style="{StaticResource IconButton}" Width="28" Height="28" ToolTip="Custom...">
                        <TextBlock Text="＋" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}" />
                    </Button>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="{DynamicResource WorkspaceCreate_Cancel}" Style="{StaticResource CmuxButton}" Padding="12,6" Margin="0,0,8,0" Click="Cancel_Click" />
                    <Button Content="{DynamicResource WorkspaceCreate_Create}" Style="{StaticResource AccentButton}" Padding="14,6" Click="Create_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
