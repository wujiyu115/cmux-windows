<UserControl x:Class="Cmux.Controls.WorkspaceGroupHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="Transparent" Padding="8,6" Cursor="Hand"
            MouseLeftButtonUp="OnHeaderClick">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource Group_Rename}" Click="Rename_Click"/>
                <MenuItem Header="{DynamicResource Group_Delete}" Click="Delete_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="ArrowText" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                       FontSize="10" Foreground="{DynamicResource ForegroundDimBrush}"
                       VerticalAlignment="Center" Margin="0,0,6,0"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <RotateTransform x:Name="ArrowRotation" Angle="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock x:Name="NameText" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundDimBrush}"
                       VerticalAlignment="Center"/>
            <TextBox x:Name="RenameBox" FontSize="11" FontWeight="SemiBold"
                     Visibility="Collapsed" Margin="-2,0,0,0"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     BorderThickness="0" Padding="2,0"
                     KeyDown="RenameBox_KeyDown" LostFocus="RenameBox_LostFocus"/>
        </StackPanel>
    </Border>
</UserControl>
