<UserControl x:Class="Cmux.Controls.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Cmux.Controls"
             HorizontalAlignment="Center" VerticalAlignment="Top"
             Margin="0,60,0,0" Width="550" MaxHeight="400"
             Visibility="Collapsed">
    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.4" Direction="270" />
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform x:Name="PaletteScale" ScaleX="1" ScaleY="1" CenterX="275" CenterY="0" />
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Row 0: Search input -->
            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="{DynamicResource ForegroundDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox x:Name="SearchInput" Grid.Column="1"
                             Background="Transparent" Foreground="{DynamicResource ForegroundBrush}"
                             CaretBrush="{DynamicResource AccentBrush}" BorderThickness="0"
                             FontSize="14" VerticalContentAlignment="Center"
                             TextChanged="SearchInput_TextChanged"
                             KeyDown="SearchInput_KeyDown" />
                </Grid>
            </Border>

            <!-- Row 1: Results list -->
            <ListBox x:Name="ResultsList" Grid.Row="1"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="ResultsList_SelectionChanged"
                     MouseDoubleClick="ResultsList_MouseDoubleClick"
                     PreviewMouseLeftButtonUp="ResultsList_PreviewMouseLeftButtonUp"
                     VirtualizingPanel.IsVirtualizing="True">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" Padding="12,8" CornerRadius="6" Margin="4,1"
                                            Background="Transparent" Cursor="Hand">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SidebarItemSelectedBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Icon -->
                            <TextBlock Grid.Column="0" Text="{Binding Item.Icon}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource ForegroundDimBrush}" VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <!-- Label (with fuzzy match highlighting) + Description -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock controls:HighlightBehavior.HighlightSource="{Binding}"
                                           Foreground="{DynamicResource ForegroundBrush}" FontSize="13" />
                                <TextBlock Text="{Binding Item.Description}" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="12"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding Item.Description, Converter={StaticResource NullToCollapsed}}" />
                            </StackPanel>
                            <!-- Shortcut -->
                            <Border Grid.Column="2" Background="{DynamicResource SidebarItemHoverBrush}" CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Item.Shortcut, Converter={StaticResource NullToCollapsed}}">
                                <TextBlock Text="{Binding Item.Shortcut}" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyText" Grid.Row="1"
                       Text="{DynamicResource Palette_NoMatching}" Foreground="{DynamicResource ForegroundDimBrush}"
                       FontSize="13" HorizontalAlignment="Center"
                       Margin="0,20,0,20" Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
